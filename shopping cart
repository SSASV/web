<!DOCTYPE html>
<html>
<head>
  <title>Shopping Cart Manager</title>
  <style>
    body { 
      font-family: Arial, sans-serif; 
      margin: 0; 
      background: #001f3f; /* dark blue background */
      color: #ffffff; /* white text for contrast *
    }
    header {
      background: #003366;
      padding: 15px;
      text-align: right; /* aligns content to the right */
      color: #ffffff;
      font-size: 18px;
      font-weight: bold;
    }
    h2 { color: #66ccff; }
    .products, .cart { width: 80%; margin: 20px auto; }
    .product { 
      border: 1px solid #66ccff; 
      background: #00264d; 
      padding: 15px; 
      margin: 10px; 
      display: inline-block; 
      width: 200px; 
      text-align: center; 
      box-shadow: 2px 2px 5px rgba(255,255,255,0.2);
      color: #ffffff;
    }
    .product img { width: 100px; height: 100px; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; background: #00264d; color: #ffffff; }
    th, td { border: 1px solid #66ccff; padding: 10px; text-align: center; }
    button { 
      margin: 5px; 
      background: #66ccff; 
      color: #001f3f; 
      border: none; 
      padding: 6px 12px; 
      cursor: pointer; 
      border-radius: 4px;
      font-weight: bold;
    }
    button:hover { background: #3399ff; color: #ffffff; }
  </style>
</head>
<body>
  <header>
    Sanjana - Roll No: 2023007377
  </header>

  <h2 style="text-align:center;">🛍️ Product Catalog</h2>
  
  <div class="products" id="productList"></div>

  <h2 style="text-align:center;">🛒 Shopping Cart</h2>
  <div class="cart">
    <button onclick="clearCart()">Clear Cart</button>
    <table id="cartTable">
      <thead>
        <tr>
          <th>Item</th><th>Price</th><th>Quantity</th><th>Total</th><th>Action</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
    <h3 id="summary"></h3>
  </div>

<script>
// Expanded product catalog
const products = [
  { id: 1, name: "Laptop", price: 55000, img: "https://via.placeholder.com/100" },
  { id: 2, name: "Mouse", price: 500, img: "https://via.placeholder.com/100" },
  { id: 3, name: "Keyboard", price: 1500, img: "https://via.placeholder.com/100" },
  { id: 4, name: "Headphones", price: 2000, img: "https://via.placeholder.com/100" },
  { id: 5, name: "Smartphone", price: 30000, img: "https://via.placeholder.com/100" },
  { id: 6, name: "Tablet", price: 20000, img: "https://via.placeholder.com/100" },
  { id: 7, name: "Smartwatch", price: 8000, img: "https://via.placeholder.com/100" },
  { id: 8, name: "Camera", price: 25000, img: "https://via.placeholder.com/100" },
  { id: 9, name: "Printer", price: 12000, img: "https://via.placeholder.com/100" },
  { id: 10, name: "External Hard Drive", price: 6000, img: "https://via.placeholder.com/100" },
  { id: 11, name: "Monitor", price: 15000, img: "https://via.placeholder.com/100" },
  { id: 12, name: "Gaming Console", price: 40000, img: "https://via.placeholder.com/100" }
];

let cart = JSON.parse(localStorage.getItem("cart")) || [];

function saveCart() {
  localStorage.setItem("cart", JSON.stringify(cart));
}

function renderProducts() {
  const productList = document.getElementById("productList");
  productList.innerHTML = "";
  products.forEach(p => {
    productList.innerHTML += `
      <div class="product">
        <img src="${p.img}" alt="${p.name}">
        <h4>${p.name}</h4>
        <p>₹${p.price}</p>
        <button onclick="addToCart(${p.id})">Add to Cart</button>
      </div>
    `;
  });
}

function renderCart() {
  const tbody = document.querySelector("#cartTable tbody");
  tbody.innerHTML = "";
  let subtotal = 0;

  cart.forEach((item, index) => {
    let row = `<tr>
      <td>${item.name}</td>
      <td>₹${item.price}</td>
      <td>${item.quantity}</td>
      <td>₹${item.price * item.quantity}</td>
      <td>
        <button onclick="increaseQty(${index})">+</button>
        <button onclick="decreaseQty(${index})">-</button>
        <button onclick="deleteItem(${index})">Delete</button>
      </td>
    </tr>`;
    tbody.innerHTML += row;
    subtotal += item.price * item.quantity;
  });

  let discount = subtotal > 10000 ? subtotal * 0.05 : 0;
  let finalTotal = subtotal - discount;

  document.getElementById("summary").innerHTML = 
    `Subtotal: ₹${subtotal} | Discount: ₹${discount} | Final Total: ₹${finalTotal}`;
}

function addToCart(productId) {
  const product = products.find(p => p.id === productId);
  const existing = cart.find(item => item.id === productId);

  if (existing) {
    existing.quantity++;
  } else {
    cart.push({ ...product, quantity: 1 });
  }
  saveCart();
  renderCart();
}

function increaseQty(index) {
  cart[index].quantity++;
  saveCart();
  renderCart();
}

function decreaseQty(index) {
  if (cart[index].quantity > 1) {
    cart[index].quantity--;
  } else {
    cart.splice(index, 1);
  }
  saveCart();
  renderCart();
}

function deleteItem(index) {
  cart.splice(index, 1);
  saveCart();
  renderCart();
}

function clearCart() {
  cart = [];
  saveCart();
  renderCart();
}

// Initial render
renderProducts();
renderCart();
</script>
</body>
</html>
